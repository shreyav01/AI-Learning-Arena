# Copy this file to .env and fill in your values
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=mistralai/mistral-7b-instruct   # or any model on OpenRouter
EMBEDDING_MODEL=paraphrase-MiniLM-L3-v2          # 2x faster than all-MiniLM-L6-v2, minimal quality loss
CHUNK_SIZE=800                                    # larger chunks = fewer embeddings = faster
CHUNK_OVERLAP=80                                  # overlap between chunks
TOP_K_CHUNKS=5                                    # top chunks to retrieve for RAG
UPLOAD_DIR=uploads
VECTOR_STORE_DIR=vector_store
